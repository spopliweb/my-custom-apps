<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="point_of_sale.SelectPartnerButton" t-inherit-mode="extension">
        <xpath expr="//button" position="after">
       
                <button
                    class="button mobile-more-button btn btn-light btn-lg flex-fill"
                    t-on-click="() => this.onClickPopupSingleField()">
                    <i class="calculator me-1"/> <span>Enter Amount</span>
                </button>
        </xpath>
    </t>
</templates>
